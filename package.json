{
  "name": "blast-radius",
  "version": "0.2.0",
  "description": "Compute the dependency blast radius of a code change in a JS/TS project, rank change hotspots, and detect cycles and dead code.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": { "blast-radius": "dist/cli.js" },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": { "test": "vitest run", "build": "tsc -p tsconfig.json", "prepare": "npm run build" },
  "keywords": ["dependency-graph", "monorepo", "impact-analysis", "typescript", "imports", "dead-code", "cli"],
  "author": "Joshua John <josh202@gmail.com>",
  "license": "MIT",
  "devDependencies": { "vitest": "^4.0.0", "typescript": "^5.4.0", "@types/node": "^22.19.21" }
}
